# Netlify environment variables for ReelRivals live scoring
# Fill in values, then import this file in Netlify UI (Environment Variables → Import).

# InstantDB (client)
VITE_INSTANT_APP_ID=your_instant_app_id_here
VITE_INSTANT_SECRET=your_instant_secret_here

# InstantDB (server-only) – do not use the VITE_ prefix when storing secrets.
INSTANT_APP_ID=your_instant_app_id_here
INSTANT_APP_ADMIN_TOKEN=your_instant_admin_token_here

